---
import Button from "@/components/common/Button.astro"
import Badge from "@/components/common/Badge.astro"
import Contact from '@/components/Contact.astro';

import LinkedIn from "@/assets/LinkedIn.svg"
import GitHub from "@/assets/gitHub.svg"
import Ws from "@/assets/ws.svg"
import DownLoad from "@/assets/DownLoad.svg"

import { getCollection } from "astro:content"

const jobs = await getCollection("jobs");
const info = await getCollection("info");

const formatDate = (dateString: string) => {
  const date = new Date(dateString);

  const formatted = new Intl.DateTimeFormat("en", {
    month: "short",
    year: "numeric",
  }).format(date);

  return formatted
};
---

 <div id="container" class="my-6">
    <main class="divide-y divide-gray-500">

      <!-- Hero / About -->
      <section 
        id="hero" 
        class="mx-4 py-8 md:py-14"
        aria-labelledby="about-heading" 
      >
        <div class="lg:max-w-7xl md:m-auto md:gap-12 grid grid-cols-1 md:grid-cols-2">
          
          <h1
            id="about-heading"
            class="text-6xl lg:text-7xl font-medium text-white font-family-sans mb-2"
          >
            About me
          </h1>

          <div>
            <!-- Párrafo lead: keywords naturales, visible para crawlers -->
            <p class="text-2xl/9 text-white text-left mb-4">
              I'm <strong>Esteban Diaz</strong>, a <strong>Frontend Developer</strong> based in <strong>Bogotá, Colombia</strong>, specializing in React, Next.js, and TypeScript.
            </p>

            <!-- Párrafo de detalle: describe experiencia real y diferenciadores -->
            <p class="text-base/7 text-left mb-4 lg:mb-8">
                With 4+ years of professional experience, I focus on building accessible, scalable web applications. 
                I have led technical teams on platforms serving major financial institutions and am passionate about solving complex problems 
                through clean code and user-centered design. My background in Computer Engineering combined with hands-on development experience 
                enables me to bridge the gap between architecture and implementation. I'm particularly interested in FinTech innovations and how 
                technology can democratize financial services in Latin America. Beyond coding, I enjoy photography, exploring new technologies, 
                and contributing to the developer community.
            </p>

            <div class="flex gap-4">
              <Button
                size="lg"
                class="w-fit pl-3 py-3"
                aria-label="Download Resume PDF"
              >
                <span class="uppercase font-bold">Download Resume</span>
                <div class="rounded-full bg-black color-white p-2">
                  <DownLoad fill="#fff" class="text-white" width={20} height={20} />
                </div>
              </Button>

              <!-- Links con aria-label descriptivos — Google los indexa -->
              <Button
                size="icon-xs"
                variant="secondary"
                class="w-fit p-2"
                href="https://www.linkedin.com/in/esteban-velasquez-diaz-19106277"
                aria-label="Perfil de LinkedIn de Esteban Diaz"  
                rel="noopener noreferrer"                       
                target="_blank"
              >
                <LinkedIn fill="currentColor" />
              </Button>

              <Button
                size="icon-xs"
                variant="secondary"
                class="w-fit p-2"
                href="https://github.com/esteban2368"
                aria-label="Perfil de GitHub de Esteban Diaz" 
                rel="noopener noreferrer"
                target="_blank"
              >
                <GitHub fill="currentColor" />
              </Button>

              <Button
                size="icon-xs"
                variant="secondary"
                class="w-fit p-2"
                href="https://wa.me/573209249866"
                aria-label="Contactar a Esteban Diaz por WhatsApp"
                rel="noopener noreferrer"
                target="_blank"
              >
                <Ws fill="currentColor" />
              </Button>
            </div>
          </div>

          <div class="lg:h-20"></div>
        </div>
      </section>

      <!-- Capabilities -->
      <section 
        id="capabilities" 
        class="mx-4 py-8 md:py-14"
        aria-labelledby="capabilities-heading"
      >
        <div class="lg:max-w-7xl md:m-auto md:gap-12 grid grid-cols-1 md:grid-cols-2">
          <h2 
            id="capabilities-heading"
            class="text-5xl lg:text-6xl font-medium text-white font-family-sans mb-2"
          >
            My Capabilities
          </h2>
          <div>
            <p class="text-base/7 text-left mb-4 lg:mb-8">
              I continuously expand my skillset across frontend technologies, backend services, and DevOps practices. Proficient in modern JavaScript frameworks and committed to best practices in code quality, accessibility, and performance optimization.
            </p>
            <div class="flex flex-wrap gap-4">
              {info && info.map(data => (
                data.data.skills.map(skill => (
                  <Badge variant="secondary">{skill}</Badge>
                ))
              ))}
            </div>
          </div>
        </div>
      </section>

      <!-- Experience -->
      <section 
        id="experience" 
        class="mx-4 py-8 lg:py-12"
        aria-labelledby="experience-heading"
      >
        <div class="lg:max-w-7xl md:m-auto md:gap-12 grid grid-cols-1 md:grid-cols-2">
          <h2 
            id="experience-heading"
            class="text-5xl lg:text-6xl font-medium text-white font-family-sans mb-4"
          >
            My Experience
          </h2>
          <div>
            <div class="flex flex-col gap-12 lg:gap-20">
              {jobs && jobs.map((job) => (
                <article
                  class="flex flex-col gap-4"
                  itemscope 
                  itemtype="https://schema.org/WorkExperience"
                >
                  <div>
                    <div class="lg:flex lg:justify-between">
                      <h3 
                        class="text-white text-lg mb-2"
                        itemprop="jobTitle"   
                      >
                        {job.data.jobTitle}
                      </h3>
                      <time 
                        itemprop="startDate" 
                        datetime={job.data.startDate}
                      >
                        {`${formatDate(job.data.startDate)} • ${formatDate(job.data.endDate)}`}
                      </time>
                    </div>
                    <p class="mb-1" itemprop="name">
                      {job.data.webSite ? (
                        <a 
                          href={job.data.webSite} 
                          target="_blank" 
                          itemprop="worksFor"
                          class="text-primary underline font-bold"
                          rel="noopener noreferrer"
                        >
                          {job.data.company}
                        </a>
                      ) : <span itemprop="worksFor">{job.data.company}</span>}
                    </p>
                  </div>
                  <p class="text-base/7" itemprop="description">
                    {job.data.companyDescription}
                  </p>
                </article>
              ))}
            </div>
          </div>
        </div>
      </section>

      <Contact/>

    </main>
  </div>
