---
import Menu from '../assets/menu.svg';
import MenuButton from './MenuButton.astro';
import Dialog from './common/Dialog.astro';
---

<div id="nav" class="flex items-center justify-between p-4">
    <h1 class="text-3xl font-family-sans">Esteban Diaz</h1>
    <!--Desktop version -->
    <ul class="menu hidden md:flex font-medium p-4 gap-6">
        <li><a href="#about">About</a></li>
        <li><a href="#projects">Work</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
    <MenuButton
        class="md:hidden"
        variant="link"
        size="icon-lg"
    >
        <Menu
            fill="currentColor"
        />
    </MenuButton>
</div>
<Dialog>
    <ul class="menu text-2xl p-4 flex flex-col gap-2.5">
        <li><a href="#about">About</a></li>
        <li><a href="#projects">Work</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
</Dialog>