---
import Image from "astro/components/Image.astro";
import Button from "@/components/common/Button.astro"
import type { CollectionEntry } from "astro:content";

import ArrowUp from "@/assets/arrowUp.svg"

type Project = CollectionEntry<"projects">['data']

type Props = Project;

const Project = Astro.props
---
<div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16 last:mb-0">
    <div class="rounded-lg px-5 py-10 bg-secondary">
        <Image
            src={Project.poster}
            alt={Project.title}
        />
    </div>
    <div class="flex flex-col gap-4">
        <div>
            <h2 class="font-medium text-white text-2xl mb-3">{Project.title}</h2>
            <p class="mb-2">{Project.description}</p>
        </div>
        <div>
            <h3 class="font-semibold uppercase ">Project Info</h3>
            <ul role="list" class="divide-y divide-gray-500">
                <li class="flex justify-between py-4">
                    <p class="font-medium text-white">Client</p>
                    <p class="font-medium">{Project.client}</p>
                </li>
                <li class="flex justify-between py-4">
                    <p class="font-medium text-white">Role</p>
                    <p class="font-medium">{Project.role}</p>
                </li>
                <li class="flex justify-between py-4">
                    <p class="font-medium text-white">Date</p>
                    <p class="font-medium">{Project.date}</p>
                </li>
            </ul>
        </div>
        <div class="flex">
            <a href={Project.website} target="_blank" class="flex gap-3 text-primary border-b px-0 py-2">
                <span class="uppercase font-family-mono font-bold w-fit">View project</span>
                <ArrowUp
                    class="w-fit"
                    color="currentcolor"
                    width={25}
                    height={25}
                />
            </a>
        </div>
    </div>
</div>

