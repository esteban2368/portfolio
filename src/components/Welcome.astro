---
import { Image } from 'astro:assets';
import { getCollection } from "astro:content";

import Button from "@/components/common/Button.astro"
import ProjectCard from '@/components/ProjectCard.astro';

import ArrowUp from "@/assets/arrowUp.svg"
import LinkedIn from "@/assets/LinkedIn.svg"
import GitHub from "@/assets/gitHub.svg"
import portait from "@/assets/portait.png"

const projects = await getCollection("projects");
---

<div id="container" class="my-6">
	<main>
		<!--Hero section -->
		<section id="hero" class="px-4">
			<section class="flex flex-col gap-5">
				<h2 class="text-6xl font-family-sans">Hi, i am </br> Esteban diaz </h2>
				<p>A Sydney based front-end developer passionate about building accessible and user friendly websites.</p>
				<div class="flex gap-4">
					<Button
						size="lg"
						class="w-fit pl-3 py-3"
					>
					<span class="uppercase">Contact Me</span>
					<div class="rounded-full bg-black color-white p-2">
						<ArrowUp
							class="text-white"
							width={20}
							height={20}
						/>
					</div>
					</Button>
					<Button
						size="icon-xs"
						variant="secondary"
						class="w-fit p-2"
					>
						<LinkedIn
							fill="currentColor"
						/>
					</Button>
					<Button
						size="icon-xs"
						variant="secondary"
						class="w-fit p-2"
					>
						<GitHub
							fill="currentColor"
						/>
					</Button>
				</div>
				<div class="overflow-hidden rounded-2xl my-8">
					<Image src={portait} alt="Portada de Esteban Diaz"/>
				</div>
			</section>
		</section>	
		<!--Projects section -->
		<section>
			<h2>Featured Projects</h2>
			<p>Here are some of the selected projects that showcase my passion for front-end development.</p>
			{projects.map(project => (
				<ProjectCard
					{...project.data}
				/>
			))}
		</section>
	</main>
</div>
